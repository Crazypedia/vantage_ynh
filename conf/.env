# Vantage server configuration (rendered by ynh_config_add at install/upgrade).
# See docs/server.md for the full list.

VANTAGE_HOST=127.0.0.1
VANTAGE_PORT=__PORT__
VANTAGE_PUBLIC_URL=__PUBLIC_URL__

# SQLite database + auto-generated master.key live here (backed up, survives upgrades).
VANTAGE_DATA_DIR=__DATA_DIR__

# Behind YunoHost's nginx: key rate limiting on the real client IP, and mark cookies Secure.
VANTAGE_TRUST_PROXY=1
VANTAGE_COOKIE_SECURE=1

# Instance allow-list (empty = accept any instance). Set at install time.
VANTAGE_ALLOWED_INSTANCES=__ALLOWED_INSTANCES__

# Global Admin bootstrap: the instance the first Global Admin logs in from.
# One-shot — inert once an admin has been claimed (manage further admins from
# the Global Admin panel inside Vantage instead).
VANTAGE_SEED_ADMIN_HOST=__SEED_ADMIN_HOST__
