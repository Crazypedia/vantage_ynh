#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# REMOVE SYSTEM CONFIGURATIONS
#=================================================
ynh_script_progression "Removing system configurations related to $app..."

if ynh_hide_warnings yunohost service status "$app" >/dev/null 2>&1; then
    yunohost service remove "$app"
fi

ynh_config_remove_systemd

ynh_config_remove_nginx

ynh_config_remove_logrotate

ynh_safe_rm "/var/log/$app"

#=================================================
# REMOVE NODEJS
#=================================================
ynh_script_progression "Removing Node.js..."

ynh_nodejs_remove

#=================================================
# REMOVE DATA DIRECTORY
#=================================================
ynh_script_progression "Removing the data directory..."

# Wipe the database AND the master key so a future reinstall starts clean and
# cannot inherit stale vaulted secrets. Upgrades never reach this script, so they
# keep data intact. Back up first if you want to keep the casework/audit history.
ynh_safe_rm "$data_dir"

#=================================================
# END OF SCRIPT
#=================================================

# The core deprovisions install_dir, the system user and the port after this script.

ynh_script_progression "Removal of $app completed"
